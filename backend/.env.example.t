# WebDoctor AI - Environment Configuration Example

# Groq AI API Key (Primary AI Recommendations)
# Get your key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Supabase Cloud Database (For scaling history storage)
# Get your key at: https://supabase.com/
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_public_key_here

# Google PageSpeed Insights API Key (Optional)
# Get your key at: https://developers.google.com/speed/docs/insights/v5/get-started
GOOGLE_PAGESPEED_API_KEY=your_google_pagespeed_api_key_here

# Wappalyzer API Key (Optional)
WAPPALYZER_API_KEY=your_wappalyzer_api_key_here

# Application Configuration
ENVIRONMENT=development
CORS_ORIGINS=["*"]
